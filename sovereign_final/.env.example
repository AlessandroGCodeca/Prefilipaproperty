# Sovereign RE Dashboard — Environment Variables
# Copy this file to .env and fill in your values

# Database password (used by Docker Compose)
DB_PASSWORD=sovereign2026

# PostgreSQL connection (auto-set by Docker, leave as-is)
DATABASE_URL=postgresql://sovereign:sovereign2026@db:5432/sovereign

# Google Places API (for Location IQ + Satellite Viewer)
# Get at: console.cloud.google.com → Enable Places API + Geocoding API
# Free $200/month credit — sufficient for personal use
GOOGLE_PLACES_API_KEY=

# Slovak Cadastral API (for LV debt checking)
# Register at: https://www.skgeodesy.sk/en/ugkk/cadastral-portal/
CADASTRAL_API_KEY=

# FinStat API (optional — company/owner lookup)
# Register at: https://finstat.sk/api
FINSTAT_API_KEY=

# ScraperAPI — REQUIRED if running on a cloud/server IP that is blocked by real estate sites
# Free tier: 5,000 requests/month — enough for daily scraping
# Sign up free at: https://www.scraperapi.com
# Without this key the scrapers make direct requests (works on home/residential internet)
SCRAPER_API_KEY=

# Docker Model Runner (auto-configured, leave as-is)
DMR_ENDPOINT=http://model-runner:12434/v1
LLM_MODEL=mistral:7b-instruct-q4_k_m
